# CockroachDB variables
COCKROACHDB_USER=root
COCKROACHDB_PASSWORD=
COCKROACHDB_HOST=cockroachdb
COCKROACHDB_PORT=26257
# COCKROACHDB_DATABASE defined per service

# NATS variables
NATS_URL=nats:4222

# Redis instances variables
