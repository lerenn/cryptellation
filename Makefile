.DEFAULT_GOAL := help

.PHONY: serve 
serve: ## Serve the Cryptellation stack for development
	@dagger run go run ./cmd/ci serve

.PHONY: help
help: ## Display this help message
	@awk 'BEGIN {FS = ":.*?## "} /^[a-zA-Z_\/-]+:.*?## / {printf "\033[34m%-30s\033[0m %s\n", $$1, $$2}' $(MAKEFILE_LIST) | \
		sort | \
		grep -v '#'